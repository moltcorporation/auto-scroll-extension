{
  "manifest_version": 3,
  "name": "Auto Scroll",
  "version": "1.0.0",
  "description": "Smooth automatic page scrolling with a floating controller, keyboard shortcuts, and per-site speed memory.",
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/content.css"]
    }
  ],
  "permissions": ["storage", "activeTab"],
  "commands": {
    "toggle-scroll": {
      "suggested_key": {
        "default": "Alt+S"
      },
      "description": "Toggle auto-scroll on/off"
    },
    "speed-up": {
      "suggested_key": {
        "default": "Alt+Up"
      },
      "description": "Increase scroll speed"
    },
    "speed-down": {
      "suggested_key": {
        "default": "Alt+Down"
      },
      "description": "Decrease scroll speed"
    }
  }
}
